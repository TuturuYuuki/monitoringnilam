# Miscellaneous
*.class
*.log
*.pyc
*.swp
.DS_Store
.atom/
.buildlog/
.history
.svn/
migrate_working_dir/

# IntelliJ related
*.iml
*.ipr
*.iws
.idea/

# The .vscode folder contains launch configuration and tasks you configure in
# VS Code which you may wish to be included in version control, so this line
# is commented out by default.
#.vscode/

# Flutter/Dart/Pub related
**/doc/api/
**/ios/Flutter/.last_build_id
.dart_tool/
.flutter-plugins
.flutter-plugins-dependencies
.pub-cache/
.pub/
/build/

# Symbolication related
app.*.symbols

# Obfuscation related
app.*.map.json

# Android Studio will place build artifacts here
/android/app/debug
/android/app/profile
/android/app/release

# ============================================
# SENSITIVE CONFIGURATION FILES
# ============================================
# Email credentials and API keys - NEVER commit these!
config/email.php
config/*.local.php
config/api_keys.php

# Email log files (may contain sensitive data)
emails.log
*.log

# Environment-specific files
.env
.env.local
.env.*.local

# ============================================
# BACKEND & DATABASE FILES (Not for public repo)
# ============================================
# PHP Backend files
*.php

# SQL and Database files
*.sql

# PowerShell scripts
*.ps1

# HTML test files
test_*.html

# ============================================
# TECHNICAL DOCUMENTATION (Keep private)
# ============================================
# Exclude all MD files except README.md
*.md
!README.md

# Technical guide files
*_GUIDE.md
*_COMPLETE.md
*_SUMMARY.md
*_FIX.md
*_DEBUG.md
*_SETUP.md
*_IMPLEMENTATION.md
*_REPORT.md
