        left: 0.60, top: 0.04, width: 0.38, height: 0.44,
      ),
      ContainerYardArea(
        id: 'PARKING', label: 'PARKING AREA',
        bgColor: const Color(0xFFBBDEFB).withOpacity(0.7),
        borderColor: const Color(0xFF2196F3),
        left: 0.60, top: 0.52, width: 0.18, height: 0.44,
