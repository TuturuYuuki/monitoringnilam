    'Tower 12A - CY1': {'cx': 0.06, 'cy': 0.70},
    
    // KIRI AGAK TENGAH (T10, T12)
    'Tower 10 - CY1':  {'cx': 0.25, 'cy': 0.30},
    'Tower 12 - CY1':  {'cx': 0.25, 'cy': 0.70},
    
